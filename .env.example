NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=xxxx
CLERK_SECRET_KEY=xxxx

DATABASE_URL=postgresql://user:pass@ep-...neon.tech/neondb?sslmode=require
MOCK_API_USERS=xxx
JSON_PLACEHOLDER_USERS=xxx

# Sentry (error tracking) — get DSN from https://sentry.io/settings/projects/
# NEXT_PUBLIC_SENTRY_DSN is needed for client-side errors (available in browser).
# SENTRY_DSN is used as fallback for server/edge runtimes.
NEXT_PUBLIC_SENTRY_DSN=https://public@o.ingest.sentry.io/project
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN only needed for source map uploads during build
